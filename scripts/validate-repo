#!/usr/bin/env ruby
# frozen_string_literal: true

require "date"
require "digest"
require "shellwords"
require "yaml"

# Prompt and archive files legitimately contain UTF-8 characters (em dashes,
# arrows). Without this, File.read inherits the locale's default external
# encoding, so under an ASCII locale (e.g. LANG unset or LANG=C) the first
# String#match? against a non-ASCII byte raises
# "invalid byte sequence in US-ASCII". Force UTF-8 so validation is
# locale-independent.
Encoding.default_external = Encoding::UTF_8

ROOT = File.expand_path("..", __dir__)
REQUIRED_PROMPT_FIELDS = %w[Goal Metric Direction Verify Guard Iterations Protocol].freeze
REQUIRED_FRONTMATTER = %w[type created tags].freeze
REQUIRED_ARCHIVE_FRONTMATTER = %w[type title last_verified access_checked tags].freeze
REQUIRED_FIXTURES = %w[
  fixtures/minimal-vault/Family_Tree.md
  fixtures/minimal-vault/Open_Questions.md
  fixtures/minimal-vault/Research_Log.md
  fixtures/minimal-vault/templates/person.md
  fixtures/golden-runs/01-tree-expansion.md
].freeze
REQUIRED_NORMIE_FILES = %w[
  START_HERE.md
  guides/download-and-start.md
  guides/prompt-picker.md
  guides/privacy-mode.md
  guides/no-obsidian-setup.md
  guides/bundles/beginner-pack.md
  guides/bundles/document-pack.md
  guides/bundles/dna-pack.md
  guides/bundles/verification-pack.md
  guides/bundles/advanced-pack.md
  checklists/first-week-checklist.md
  checklists/scan-your-documents.md
  checklists/interview-a-relative.md
  checklists/verify-an-ai-finding.md
  checklists/before-you-add-an-ancestor.md
  checklists/share-safely.md
  walkthroughs/first-run.md
  guides/plain-language/source-grades.md
  guides/plain-language/evidence-vs-clues.md
  guides/plain-language/why-ai-can-be-wrong.md
  guides/plain-language/what-counts-as-proof.md
].freeze
CANONICAL_CORE_PATHS = {
  "unresolved_persons.md" => "Unresolved_Persons.md",
  "chromosome_painting.md" => "Chromosome_Painting.md",
  "family_tree.md" => "Family_Tree.md",
  "open_questions.md" => "Open_Questions.md",
  "research_log.md" => "Research_Log.md",
  "data_inventory.md" => "Data_Inventory.md",
  "genetic_profile.md" => "Genetic_Profile.md",
  "witness_network.md" => "Witness_Network.md",
  "research_strategy.md" => "Research_Strategy.md"
}.freeze
PUBLIC_PRIVACY_PATTERNS = [
  {
    label: "absolute Matt home path",
    pattern: Regexp.new("/Users/" + "mattprusak" + "/")
  },
  {
    label: "private vault name",
    pattern: Regexp.new(["Pru", "sak"].join + " Vault")
  },
  {
    label: "US Social Security number pattern",
    pattern: /\b\d{3}-\d{2}-\d{4}\b/
  }
].freeze
FIRST_RUN_ROUTE_FILES = %w[
  README.md
  prompts/README.md
  workflows/getting-started.md
].freeze
FIRST_RUN_FORBIDDEN_PATTERNS = [
  {
    label: "expansion-first quick start",
    pattern: /Open Claude Code, paste the contents of `prompts\/01-tree-expansion\.md`/
  },
  {
    label: "start from scratch with expansion",
    pattern: /Start with `01-tree-expansion`/
  },
  {
    label: "expansion before audit",
    pattern: /After expanding the tree, verify/
  },
  {
    label: "raw growth reporting",
    pattern: /Report how many new individuals were found/
  },
  {
    label: "old expansion workflow heading",
    pattern: /^## Step 4: Run the Tree Expansion Prompt/
  }
].freeze

@errors = []

def rel(path)
  path.delete_prefix("#{ROOT}/")
end

def error(message)
  @errors << message
end

def read(path)
  File.read(File.join(ROOT, path))
end

def term_label(term)
  "sha256:#{Digest::SHA256.hexdigest(term)[0, 12]} len:#{term.length}"
end

def frontmatter_for(path)
  text = File.read(path)
  unless text.start_with?("---\n")
    error("#{rel(path)}: missing YAML frontmatter")
    return {}
  end

  parts = text.split(/^---\s*$/, 3)
  yaml = parts[1]
  YAML.safe_load(yaml, permitted_classes: [Date]) || {}
rescue Psych::SyntaxError, Psych::DisallowedClass => e
  error("#{rel(path)}: invalid YAML frontmatter: #{e.message}")
  {}
end

def check_prompts
  prompt_paths = Dir[File.join(ROOT, "prompts/[0-9]*.md")].sort
  error("expected 14 numbered prompts, found #{prompt_paths.length}") unless prompt_paths.length == 14

  prompt_paths.each do |path|
    text = File.read(path)
    REQUIRED_PROMPT_FIELDS.each do |field|
      error("#{rel(path)}: missing **#{field}** field") unless text.match?(/^\*\*#{Regexp.escape(field)}\*\*:/)
    end

    input_pos = text.index("## Inputs To Replace")
    config_pos = text.index("## Autoresearch Configuration")
    if input_pos.nil?
      error("#{rel(path)}: missing ## Inputs To Replace")
    elsif config_pos && input_pos > config_pos
      error("#{rel(path)}: Inputs To Replace must appear before Autoresearch Configuration")
    end

    CANONICAL_CORE_PATHS.each do |wrong, right|
      error("#{rel(path)}: use #{right}, not #{wrong}") if text.include?(wrong)
    end
  end
end

def check_vault_frontmatter
  Dir[File.join(ROOT, "vault-template/**/*.md")].sort.each do |path|
    data = frontmatter_for(path)
    REQUIRED_FRONTMATTER.each do |key|
      error("#{rel(path)}: missing frontmatter key #{key}") unless data.key?(key)
    end
  end
end

def check_archive_frontmatter
  Dir[File.join(ROOT, "archives/*.md")].sort.each do |path|
    next if File.basename(path) == "README.md"

    data = frontmatter_for(path)
    REQUIRED_ARCHIVE_FRONTMATTER.each do |key|
      error("#{rel(path)}: missing frontmatter key #{key}") unless data.key?(key)
    end
    error("#{rel(path)}: type must be archive-guide") unless data["type"] == "archive-guide"
  end
end

def check_markdown_links
  Dir[File.join(ROOT, "**/*.md")].each do |path|
    text = File.read(path)
    text.scan(/\[[^\]\n]+\]\(([^)]+)\)/).flatten.each do |link|
      next if link.match?(/\A(?:https?:|mailto:|#)/)

      target = link.split("#", 2).first
      next if target.empty?

      resolved = File.expand_path(target, File.dirname(path))
      error("#{rel(path)}: broken markdown link #{link}") unless File.exist?(resolved)
    end
  end
end

def check_readme_counts
  readme = read("README.md")
  counts = {
    "autoresearch prompts" => Dir[File.join(ROOT, "prompts/[0-9]*.md")].length,
    "Vault Template" => Dir[File.join(ROOT, "vault-template/**/*.md")].length,
    "Archive Guides" => Dir[File.join(ROOT, "archives/*.md")].reject { |p| File.basename(p) == "README.md" }.length,
    "Reference Guides" => Dir[File.join(ROOT, "reference/*.md")].length,
    "Workflows" => Dir[File.join(ROOT, "workflows/*.md")].length,
    "Examples" => Dir[File.join(ROOT, "examples/*.md")].reject { |p| File.basename(p) == "README.md" }.length
  }

  {
    "#{counts["autoresearch prompts"]} autoresearch prompts" => "prompt count",
    "#{counts["Vault Template"]} files" => "vault-template file count",
    "#{counts["Archive Guides"]} country and region-specific guides" => "archive guide count",
    "#{counts["Reference Guides"]} methodology documents" => "reference guide count",
    "#{counts["Workflows"]} step-by-step guides" => "workflow count",
    "#{counts["Examples"]} anonymized worked examples" => "example count"
  }.each do |needle, label|
    error("README.md: missing or stale #{label}: expected '#{needle}'") unless readme.include?(needle)
  end
end

def tracked_text_files
  `git -C #{ROOT.shellescape} ls-files`.lines.map(&:strip).select do |path|
    full_path = File.join(ROOT, path)
    File.file?(full_path) && !File.binread(full_path, 1024).include?("\x00")
  end
end

def check_fixtures
  REQUIRED_FIXTURES.each do |path|
    error("#{path}: missing required fixture") unless File.exist?(File.join(ROOT, path))
  end

  fixture_text = REQUIRED_FIXTURES.map do |path|
    full_path = File.join(ROOT, path)
    File.read(full_path) if File.exist?(full_path)
  end.compact.join("\n")
  error("fixtures: missing explicit fictional-data notice") unless fixture_text.match?(/fictional|synthetic/i)
  error("fixtures: golden run must demonstrate living-person skip") unless fixture_text.match?(/Living/) && fixture_text.match?(/skip/i)
end

def check_public_privacy_patterns
  tracked_text_files.each do |path|
    next if path == "LICENSE"

    text = File.read(File.join(ROOT, path))
    PUBLIC_PRIVACY_PATTERNS.each do |rule|
      next unless text.match?(rule[:pattern])

      error("#{path}: contains #{rule[:label]}")
    end
  end
end

def check_review_cards
  prompt_paths = Dir[File.join(ROOT, "prompts/[0-9]*.md")].sort
  prompt_paths.each do |path|
    base = File.basename(path)
    card_path = File.join(ROOT, "review-cards", base)
    error("review-cards/#{base}: missing review card for #{rel(path)}") unless File.exist?(card_path)
  end

  card_paths = Dir[File.join(ROOT, "review-cards/[0-9]*.md")].sort
  error("expected #{prompt_paths.length} review cards, found #{card_paths.length}") unless card_paths.length == prompt_paths.length

  card_paths.each do |path|
    text = File.read(path)
    %w[Good\ Output Red\ Flags Verify\ Manually Reject\ The\ Result\ When Next\ Prompt].each do |heading|
      error("#{rel(path)}: missing ## #{heading}") unless text.include?("## #{heading}")
    end
  end
end

def check_normie_usability
  REQUIRED_NORMIE_FILES.each do |path|
    error("#{path}: missing required beginner usability file") unless File.exist?(File.join(ROOT, path))
  end

  privacy_mode = File.join(ROOT, "guides/privacy-mode.md")
  return unless File.exist?(privacy_mode)

  text = File.read(privacy_mode)
  error("guides/privacy-mode.md: must mention scripts/privacy-audit-repo") unless text.include?("scripts/privacy-audit-repo")
  error("guides/privacy-mode.md: must include a living-person checklist") unless text.include?("## Living-Person Checklist")
end

def check_first_run_routes
  FIRST_RUN_ROUTE_FILES.each do |path|
    text = read(path)
    FIRST_RUN_FORBIDDEN_PATTERNS.each do |rule|
      error("#{path}: #{rule[:label]} conflicts with source-first beginner route") if text.match?(rule[:pattern])
    end
  end
end

def check_optional_privacy_denylist
  denylist_path = File.join(ROOT, ".private/anonymization-denylist.txt")
  return unless File.exist?(denylist_path)

  terms = File.readlines(denylist_path, chomp: true).map(&:strip).reject do |line|
    line.empty? || line.start_with?("#")
  end
  return if terms.empty?

  tracked_text_files.each do |path|
    next if path == "LICENSE"

    text = File.read(File.join(ROOT, path))
    terms.each do |term|
      error("#{path}: contains private denylist term #{term_label(term)}") if text.include?(term)
    end
  end
end

check_prompts
check_vault_frontmatter
check_archive_frontmatter
check_markdown_links
check_readme_counts
check_fixtures
check_review_cards
check_normie_usability
check_public_privacy_patterns
check_first_run_routes
check_optional_privacy_denylist

if @errors.empty?
  puts "validate-repo: ok"
else
  warn "validate-repo: #{@errors.length} failure(s)"
  @errors.each { |message| warn "- #{message}" }
  exit 1
end

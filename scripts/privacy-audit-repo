#!/usr/bin/env ruby
# frozen_string_literal: true

require "fileutils"
require "English"
require "digest"
require "shellwords"
require "time"

ROOT = File.expand_path("..", __dir__)
DENYLIST_PATH = File.join(ROOT, ".private/anonymization-denylist.txt")
DEFAULT_REPORT_DIR = File.join(Dir.home, ".cache", "autoresearch-genealogy", "privacy-audits")
REPORT_DIR = ENV.fetch("PRIVACY_AUDIT_REPORT_DIR", DEFAULT_REPORT_DIR)
EXCLUDED_PATHS = ["LICENSE"].freeze

def run_git(*args)
  command = ["git", "-C", ROOT, *args].shelljoin
  output = `#{command} 2>&1`
  [output, $CHILD_STATUS.exitstatus]
end

def tracked_text_files
  output, status = run_git("ls-files")
  abort "git ls-files failed:\n#{output}" unless status.zero?

  output.lines.map(&:strip).select do |path|
    full_path = File.join(ROOT, path)
    File.file?(full_path) && !File.binread(full_path, 1024).include?("\x00")
  end
end

def load_terms
  unless File.exist?(DENYLIST_PATH)
    abort "Missing #{DENYLIST_PATH}. Create it with one private term per line."
  end

  terms = File.readlines(DENYLIST_PATH, chomp: true).map(&:strip).reject do |line|
    line.empty? || line.start_with?("#")
  end
  abort "No denylist terms found in #{DENYLIST_PATH}" if terms.empty?
  terms
end

def term_label(term)
  "sha256:#{Digest::SHA256.hexdigest(term)[0, 12]} len:#{term.length}"
end

def current_head_findings(terms)
  findings = []
  tracked_text_files.each do |path|
    next if EXCLUDED_PATHS.include?(path)

    text = File.read(File.join(ROOT, path))
    terms.each do |term|
      next unless text.include?(term)

      line_numbers = text.lines.each_with_index.map do |line, index|
        index + 1 if line.include?(term)
      end.compact
      findings << {
        term_label: term_label(term),
        path: path,
        lines: line_numbers
      }
    end
  end
  findings
end

def history_findings(terms)
  findings = []
  terms.each do |term|
    output, status = run_git("log", "--all", "--format=%H %s", "-S#{term}", "--", ".", ":(exclude)LICENSE")
    unless [0, 1].include?(status)
        findings << { term_label: term_label(term), error: "git log failed: #{output.strip}" }
      next
    end

    commits = output.lines.map(&:strip).reject(&:empty?)
    findings << { term_label: term_label(term), commits: commits } unless commits.empty?
  end
  findings
end

# --------------------------------------------------------------------------
# IDENTIFIER SCAN — a second class of disclosure the denylist cannot see.
#
# The denylist holds NAMES. An external record identifier is a POINTER to a
# name: paste a FamilySearch PID into familysearch.org and you get the person.
# So a code comment illustrating "strip PID-like tokens" with a REAL pid
# discloses an ancestor as surely as writing their name would, and passes a
# name-based audit clean. That happened here: four real identifiers sat in code
# comments as illustrations through three clean audit runs (22 JUL 2026), caught
# by a manual pre-push review rather than by this script.
#
# It happened once more while this very check was being written: the paragraph
# above originally quoted one of those identifiers verbatim, and the check's
# first run flagged its own explanation. Illustrate this rule with placeholders.
#
# Detected: the FamilySearch PID shape, four alphanumerics + hyphen + three.
# Measured over the tracked tree before shipping this: every occurrence was a
# placeholder, so the check starts at zero findings and any hit is real.
#
# NOT detected, deliberately: the WikiTree shape (Surname-Number). It is
# structurally identical to ordinary prose in these documents -- "Pre-1800",
# "Post-1906", "Phase-1", "Gen-2" all match it, and they outnumber real ids in
# the tracked tree by more than ten to one. A check that fires on prose is worse
# than no check, because it trains you to ignore it. That gap is real and known:
# a WikiTree id DID slip through the same manual review that caught the PIDs.
#
# HEAD ONLY, on purpose. History is not scanned for this class because the
# pre-scrub commits legitimately contain these identifiers and always will --
# rewriting published history to remove a public record pointer would be a much
# larger harm than the disclosure. The point of this check is to stop the NEXT
# one, not to relitigate what shipped.
IDENTIFIER_RE = /\b[A-Z0-9]{4}-[A-Z0-9]{3}\b/.freeze

# A token is a placeholder when its two halves are each a single repeated
# character (XXXX-XXX, AAAA-AAA), or when it is one of the deliberate stand-ins
# used in examples and fixtures.
PLACEHOLDER_IDENTIFIERS = %w[ABCD-123 EFGH-4JK].freeze

def placeholder_identifier?(token)
  return true if PLACEHOLDER_IDENTIFIERS.include?(token)

  left, right = token.split("-")
  left.chars.uniq.length == 1 && right.chars.uniq.length == 1
end

def identifier_findings
  findings = []
  tracked_text_files.each do |path|
    next if EXCLUDED_PATHS.include?(path)

    File.read(File.join(ROOT, path)).lines.each_with_index do |line, index|
      line.scan(IDENTIFIER_RE).uniq.each do |token|
        next if placeholder_identifier?(token)

        findings << { path: path, line: index + 1, token_label: term_label(token) }
      end
    end
  end
  findings
end

def write_report(terms, head_findings, git_history_findings, id_findings)
  FileUtils.mkdir_p(REPORT_DIR)
  timestamp = Time.now.utc.strftime("%Y-%m-%d-%H%M%S")
  path = File.join(REPORT_DIR, "#{timestamp}.md")

  head_sha, = run_git("rev-parse", "HEAD")
  log_count, = run_git("rev-list", "--count", "HEAD")

  content = +"# Privacy Audit\n\n"
  content << "- Generated: #{Time.now.utc.iso8601}\n"
  content << "- HEAD: `#{head_sha.strip}`\n"
  content << "- Reachable commits on current branch: #{log_count.strip}\n"
  content << "- Denylist terms checked: #{terms.length}\n"
  content << "- Excluded paths: #{EXCLUDED_PATHS.join(', ')}\n"
  content << "- Identifier shapes checked: FamilySearch PID (HEAD only)\n\n"

  content << "## Current HEAD Findings\n\n"
  if head_findings.empty?
    content << "None.\n\n"
  else
    head_findings.each do |finding|
      content << "- `#{finding[:term_label]}` in `#{finding[:path]}` lines #{finding[:lines].join(', ')}\n"
    end
    content << "\n"
  end

  content << "## Reachable History Findings\n\n"
  if git_history_findings.empty?
    content << "None.\n\n"
  else
    git_history_findings.each do |finding|
      if finding[:error]
        content << "- `#{finding[:term_label]}`: #{finding[:error]}\n"
      else
        content << "- `#{finding[:term_label]}` appears in commits:\n"
        finding[:commits].each { |commit| content << "  - #{commit}\n" }
      end
    end
    content << "\n"
  end

  content << "## Identifier Findings (HEAD only)\n\n"
  content << "Record-identifier shapes that are not recognised placeholders. An external\n"
  content << "id is a pointer to a NAME, so it discloses a person even though no denylist\n"
  content << "term appears. See the note above IDENTIFIER_RE for what is and is not scanned.\n\n"
  if id_findings.empty?
    content << "None.\n\n"
  else
    id_findings.each do |finding|
      content << "- `#{finding[:token_label]}` in `#{finding[:path]}` line #{finding[:line]}\n"
    end
    content << "\n"
  end

  content << "## Result\n\n"
  content << if head_findings.empty? && git_history_findings.empty? && id_findings.empty?
               "PASS\n"
             else
               "FAIL\n"
             end

  File.write(path, content)
  path
end

terms = load_terms
head_findings = current_head_findings(terms)
git_history_findings = history_findings(terms)
id_findings = identifier_findings
report_path = write_report(terms, head_findings, git_history_findings, id_findings)

if head_findings.empty? && git_history_findings.empty? && id_findings.empty?
  puts "privacy-audit-repo: ok"
  puts "report: #{report_path}"
else
  warn "privacy-audit-repo: #{head_findings.length + git_history_findings.length + id_findings.length} finding group(s)"
  warn "report: #{report_path}"
  exit 1
end

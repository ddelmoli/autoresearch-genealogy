#!/usr/bin/env ruby
# frozen_string_literal: true

require "fileutils"
require "English"
require "shellwords"
require "time"

ROOT = File.expand_path("..", __dir__)
DENYLIST_PATH = File.join(ROOT, ".private/anonymization-denylist.txt")
REPORT_DIR = File.join(ROOT, "privacy-audits")
EXCLUDED_PATHS = ["LICENSE"].freeze

def run_git(*args)
  command = ["git", "-C", ROOT, *args].shelljoin
  output = `#{command} 2>&1`
  [output, $CHILD_STATUS.exitstatus]
end

def tracked_text_files
  output, status = run_git("ls-files")
  abort "git ls-files failed:\n#{output}" unless status.zero?

  output.lines.map(&:strip).select do |path|
    full_path = File.join(ROOT, path)
    File.file?(full_path) && !File.binread(full_path, 1024).include?("\x00")
  end
end

def load_terms
  unless File.exist?(DENYLIST_PATH)
    abort "Missing #{DENYLIST_PATH}. Create it with one private term per line."
  end

  terms = File.readlines(DENYLIST_PATH, chomp: true).map(&:strip).reject do |line|
    line.empty? || line.start_with?("#")
  end
  abort "No denylist terms found in #{DENYLIST_PATH}" if terms.empty?
  terms
end

def current_head_findings(terms)
  findings = []
  tracked_text_files.each do |path|
    next if EXCLUDED_PATHS.include?(path)

    text = File.read(File.join(ROOT, path))
    terms.each do |term|
      next unless text.include?(term)

      line_numbers = text.lines.each_with_index.filter_map do |line, index|
        index + 1 if line.include?(term)
      end
      findings << {
        term: term,
        path: path,
        lines: line_numbers
      }
    end
  end
  findings
end

def history_findings(terms)
  findings = []
  terms.each do |term|
    output, status = run_git("log", "--all", "--format=%H %s", "-S#{term}", "--", ".", ":(exclude)LICENSE")
    unless [0, 1].include?(status)
      findings << { term: term, error: "git log failed: #{output.strip}" }
      next
    end

    commits = output.lines.map(&:strip).reject(&:empty?)
    findings << { term: term, commits: commits } unless commits.empty?
  end
  findings
end

def write_report(terms, head_findings, git_history_findings)
  FileUtils.mkdir_p(REPORT_DIR)
  timestamp = Time.now.utc.strftime("%Y-%m-%d-%H%M%S")
  path = File.join(REPORT_DIR, "#{timestamp}.md")

  head_sha, = run_git("rev-parse", "HEAD")
  log_count, = run_git("rev-list", "--count", "HEAD")

  content = +"# Privacy Audit\n\n"
  content << "- Generated: #{Time.now.utc.iso8601}\n"
  content << "- HEAD: `#{head_sha.strip}`\n"
  content << "- Reachable commits on current branch: #{log_count.strip}\n"
  content << "- Denylist terms checked: #{terms.length}\n"
  content << "- Excluded paths: #{EXCLUDED_PATHS.join(', ')}\n\n"

  content << "## Current HEAD Findings\n\n"
  if head_findings.empty?
    content << "None.\n\n"
  else
    head_findings.each do |finding|
      content << "- `#{finding[:term]}` in `#{finding[:path]}` lines #{finding[:lines].join(', ')}\n"
    end
    content << "\n"
  end

  content << "## Reachable History Findings\n\n"
  if git_history_findings.empty?
    content << "None.\n\n"
  else
    git_history_findings.each do |finding|
      if finding[:error]
        content << "- `#{finding[:term]}`: #{finding[:error]}\n"
      else
        content << "- `#{finding[:term]}` appears in commits:\n"
        finding[:commits].each { |commit| content << "  - #{commit}\n" }
      end
    end
    content << "\n"
  end

  content << "## Result\n\n"
  content << if head_findings.empty? && git_history_findings.empty?
               "PASS\n"
             else
               "FAIL\n"
             end

  File.write(path, content)
  path
end

terms = load_terms
head_findings = current_head_findings(terms)
git_history_findings = history_findings(terms)
report_path = write_report(terms, head_findings, git_history_findings)

if head_findings.empty? && git_history_findings.empty?
  puts "privacy-audit-repo: ok"
  puts "report: #{report_path.delete_prefix("#{ROOT}/")}"
else
  warn "privacy-audit-repo: #{head_findings.length + git_history_findings.length} finding group(s)"
  warn "report: #{report_path.delete_prefix("#{ROOT}/")}"
  exit 1
end
